HOST=0.0.0.0
PORT=3000
TRUST_PROXY=true

WP_AI_JWT_SECRET=replace-with-shared-secret
WP_AI_JWT_AUDIENCE=3dpolitics-ai
WP_AI_JWT_ISSUER=3dpolitics.xyz

LITELLM_API_BASE_URL=http://litellm:4000
LITELLM_API_KEY=sk-internal-gateway-key
LITELLM_TIMEOUT_MS=45000
MAX_BODY_BYTES=16384

USE_CASE_MANIFESTO_PROVIDER=anthropic
USE_CASE_MANIFESTO_MODEL=manifesto-remix
USE_CASE_MANIFESTO_MAX_OUTPUT_TOKENS=1400
USE_CASE_MANIFESTO_TEMPERATURE=0.8

USE_CASE_HOMEPAGE_CHAT_PROVIDER=openai
USE_CASE_HOMEPAGE_CHAT_MODEL=homepage-chat
USE_CASE_HOMEPAGE_CHAT_MAX_OUTPUT_TOKENS=600
USE_CASE_HOMEPAGE_CHAT_TEMPERATURE=0.4
